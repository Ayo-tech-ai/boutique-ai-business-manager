# Copy this file to secrets.toml for LOCAL development only.
# Never commit secrets.toml to GitHub — it's already in .gitignore.
#
# For Streamlit Community Cloud deployment, do NOT use this file.
# Instead, paste your keys into: App settings → Secrets, in the
# Streamlit Cloud dashboard, using the same format below.

# Google Gemini API Keys (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY_1 = "your-first-gemini-api-key-here"
GOOGLE_API_KEY_2 = "your-second-gemini-api-key-here"
